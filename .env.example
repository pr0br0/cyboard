# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Security
JWT_SECRET=your-super-secret-and-long-key-at-least-32-chars
JWT_EXPIRES_IN=30d
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:3000,https://your-production-domain.com

# File Upload
MAX_FILE_SIZE=5242880  # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Logging
LOG_LEVEL=debug  # Options: error, warn, info, debug
LOG_FORMAT=combined  # Options: combined, dev, short, tiny

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASS=your_password
SMTP_SECURE=false  # true for 465 port, false for other ports

# Cache Configuration (if using Redis)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600  # Time in seconds